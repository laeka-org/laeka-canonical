<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Laeka Local App — macOS LaunchAgent template.

  Placeholders replaced by install-laeka.sh:
    __APP_DIR__      e.g. /Users/alice/.laeka/app
    __NODE_BIN__     e.g. /usr/local/bin/node or /opt/homebrew/bin/node
    __HOME__         user home dir (for log path)

  Loaded with:
    launchctl load -w ~/Library/LaunchAgents/com.laeka.local.plist

  Restart-on-crash via KeepAlive=true. Auto-start at login via RunAtLoad=true.
-->
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.laeka.local</string>

  <key>ProgramArguments</key>
  <array>
    <string>__NODE_BIN__</string>
    <string>__APP_DIR__/server.js</string>
  </array>

  <key>WorkingDirectory</key>
  <string>__APP_DIR__</string>

  <key>EnvironmentVariables</key>
  <dict>
    <key>HOSTNAME</key>
    <string>0.0.0.0</string>
    <key>PORT</key>
    <string>3000</string>
    <key>NODE_ENV</key>
    <string>production</string>
  </dict>

  <key>RunAtLoad</key>
  <true/>

  <key>KeepAlive</key>
  <true/>

  <key>ThrottleInterval</key>
  <integer>10</integer>

  <key>StandardOutPath</key>
  <string>__HOME__/.laeka/laeka-local.log</string>

  <key>StandardErrorPath</key>
  <string>__HOME__/.laeka/laeka-local.err</string>
</dict>
</plist>
